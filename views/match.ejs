<%- include('partials/header', { title: 'Your Match' }) %>

    <main class="container text-center my-5">

      <h1 class="display-4 mb-4"> We Found a Match! </h1>

      <section class="d-flex flex-column align-items-center my-4">
        <figure>
          <img
            src="<%= photo %>"
            alt="Photo of <%= name %>"
            class="rounded shadow"
            style="height: 400px; width: 400px; object-fit: cover;"
          />
        </figure>
        <h4 class="mt-3">Your Match is <strong><%= name %></strong>!</h4>
      </section>

      <a href="/" class="btn btn-secondary text-white mt-3"> Restart Survey </a>

    </main>

<%- include('partials/footer', {}) %>
